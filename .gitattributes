# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.cs text diff=csharp
*.gd text
*.tscn text
*.tres text
*.md text
*.json text
*.yaml text
*.yml text
*.txt text

# Declare files that will always have CRLF line endings on checkout
*.sln text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.ogg binary
*.wav binary
